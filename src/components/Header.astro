---
const path = Astro.url.pathname;
const links = [
  { href: '/', label: '홈' },
  { href: '/blog/', label: '모든 글' },
  { href: '/categories/', label: '주제' },
];
---

<header class="site-header">
  <div class="shell header-inner">
    <a class="brand" href="/" aria-label="AI 실전 노트 홈">
      <span class="brand-mark" aria-hidden="true">눈</span>
      <span>
        <strong>AI 실전 노트</strong>
        <small>by 눈삽</small>
      </span>
    </a>

    <nav class="main-nav" aria-label="주요 메뉴">
      {links.map((link) => (
        <a href={link.href} aria-current={path === link.href ? 'page' : undefined}>{link.label}</a>
      ))}
    </nav>

    <button class="theme-toggle" id="theme-toggle" type="button" aria-label="다크 모드 전환">
      <span class="theme-icon" aria-hidden="true">◐</span>
      <span class="theme-label">테마</span>
    </button>
  </div>
</header>
